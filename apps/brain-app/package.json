{
  "name": "@mu-kn/brain-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "atlas:build-config": "node ../../scripts/atlas/build-config.mjs",
    "dev": "pnpm run atlas:build-config && vite",
    "build": "pnpm run atlas:build-config && tsc -b && vite build",
    "perf:budget": "node ../../scripts/perf/check-brain-app-budget.mjs",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0",
    "smoke:explorer-panel": "node scripts/smoke-explorer-panel.mjs",
    "smoke:learning-layout": "node scripts/smoke-learning-layout.mjs",
    "smoke:responsive-layout": "node scripts/smoke-responsive-layout.mjs",
    "typecheck": "pnpm run atlas:build-config && tsc -b --noEmit",
    "test": "pnpm run atlas:build-config && vitest run",
    "test:watch": "pnpm run atlas:build-config && vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@mu-kn/brain-runtime": "file:../../packages/brain-runtime",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-slot": "1.2.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.468.0",
    "nifti-reader-js": "^0.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "6.28.0",
    "smol-toml": "^1.6.1",
    "tailwind-merge": "2.5.5",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.9.9",
    "zod": "3.24.1",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@fontsource/lexend": "5.2.11",
    "@gltf-transform/core": "^4.4.0",
    "@playwright/test": "1.49.1",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-window": "^1.8.8",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "4.3.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "25.0.1",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.2",
    "vite": "5.4.11",
    "vitest": "2.1.8"
  }
}
