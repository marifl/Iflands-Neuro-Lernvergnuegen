{
  "name": "@mu-kn/brain-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "atlas:build-config": "node ../../scripts/atlas/build-config.mjs",
    "dev": "pnpm run atlas:build-config && vite",
    "generate:phineas-iron-rod": "node scripts/generate-phineas-iron-rod.mjs",
    "build": "pnpm run atlas:build-config && tsc -b && vite build",
    "docs:drift": "node ../../scripts/check-doc-drift.mjs",
    "inventory:mesh-identity": "node scripts/mesh-identity-inventory.mjs --check",
    "perf:budget": "node ../../scripts/perf/check-brain-app-budget.mjs",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0",
    "smoke:explorer-panel": "node scripts/smoke-explorer-panel.mjs",
    "smoke:learning-layout": "node scripts/smoke-learning-layout.mjs",
    "smoke:performance-gate": "node scripts/smoke-performance-gate.mjs",
    "smoke:phineas-gage": "node scripts/smoke-phineas-gage.mjs",
    "smoke:responsive-layout": "node scripts/smoke-responsive-layout.mjs",
    "typecheck": "pnpm run atlas:build-config && tsc -b --noEmit",
    "test": "pnpm run atlas:build-config && vitest run",
    "test:watch": "pnpm run atlas:build-config && vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots",
    "verify:brain-models": "node ../../scripts/atlas/check-brain-model-assets.mjs",
    "verify:phineas-transform": "node scripts/verify-phineas-transform.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "lucide-react": "0.468.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.184.0",
    "zod": "3.24.1",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.0",
    "@gltf-transform/extensions": "^4.4.0",
    "@playwright/test": "1.49.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-window": "^1.8.8",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "4.3.4",
    "draco3dgltf": "^1.5.7",
    "jsdom": "29.1.1",
    "smol-toml": "^1.7.0",
    "typescript": "5.7.2",
    "vite": "5.4.11",
    "vitest": "2.1.8"
  }
}
