{
  "_doc": "Julich-Host-Suffix (aus julich3-area-<code>-<suffix>-<l/r>) + DKT-Name -> TARO-Host-Gyrus (brain.glb). Within-Host-Partition: jede Parzelle wird in IHREM Host-Gyrus gegen die Geschwister-Parzellen zentroid-aligned partitioniert. 'combined' = synthetischer Host aus mehreren Gyri (wie geometric_pole). 'exclude' = nicht transformieren (Grund dokumentiert). Sulci (ifs/sts/ips/...) -> adjazenter Gyrus (anatomische Konvention).",

  "combined_hosts": {
    "ofc-combined": ["lateral-orbital-gyrus", "medial-orbital-gyrus", "anterior-orbital-gyrus", "posterior-orbital-gyrus", "straight-gyrus"],
    "ipl-combined": ["supramarginal-gyrus", "angular-gyrus"],
    "frontal-pole-combined": ["superior-frontal-gyrus", "middle-frontal-gyrus"],
    "insula-combined": ["insula", "first-short-gyrus-of-insula", "second-short-gyrus-of-insula", "intermediate-short-gyrus-of-insula"],
    "heschl-combined": ["anterior-transverse-temporal-gyrus", "posterior-transverse-temporal-gyrus"]
  },

  "_host_restrictions_doc": "Manche Parzellen bewohnen einen Host, den sie NICHT tilen (z.B. nur fp1/fp2 im ganzen SFG+MFG -> blaehen auf beide Haelften statt nur den Pol). Restriction beschneidet die Host-Geometrie VOR der Partition auf eine Region (anteriore mm-Kappe), Achse +Z=anterior. Gilt bei host_vertices() ueberall.",
  "host_restrictions": {
    "frontal-pole-combined": { "axis": "z", "anterior_mm": 25 }
  },

